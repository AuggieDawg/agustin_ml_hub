generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma v7 + prisma.config.ts:
  // The connection URL is configured in prisma.config.ts, not here.
}

enum TaskScope {
  PORTAL
  OWNER
}

enum Role {
  USER
  ADMIN
}

enum WorkbenchTaskStatus {
  Open
  InProgress
  Review
  Completed
  Overdue
}

enum WorkbenchTaskPriority {
  Low
  Medium
  High
}

enum SecurityPropertyAccessRole {
  Viewer
  Operator
  Billing
  Admin
}

enum SecurityDeviceType {
  CAMERA
  DOOR_SENSOR
  WINDOW_SENSOR
  MOTION_SENSOR
  SMOKE_DETECTOR
  CO_DETECTOR
  LOCK
  PANEL
  SIREN
  FLOOD_SENSOR
  OTHER
}

enum SecurityDeviceStatus {
  UNCONFIGURED
  ONLINE
  WARNING
  OFFLINE
  MAINTENANCE
}

enum CameraTransport {
  RTSP
  HLS
  WEBRTC
  ONVIF
  OTHER
}

enum CameraStreamKind {
  LIVE
  SUBSTREAM
  RECORDING
  SNAPSHOT
}

enum CameraStreamStatus {
  UNCONFIGURED
  CONNECTING
  LIVE
  DEGRADED
  OFFLINE
}

enum SecurityAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum SecurityAlertStatus {
  Open
  Acknowledged
  Resolved
}

enum SecurityEventType {
  MANUAL
  DEVICE_HEARTBEAT
  MOTION_DETECTED
  DOOR_OPENED
  DOOR_CLOSED
  CAMERA_OFFLINE
  CAMERA_RESTORED
  SYSTEM_ARMED
  SYSTEM_DISARMED
  RECORDING_STARTED
  RECORDING_STOPPED
}

enum ServiceTicketPriority {
  Low
  Medium
  High
  Urgent
}

enum ServiceTicketStatus {
  Open
  Scheduled
  InProgress
  Resolved
  Closed
}

enum InvoiceStatus {
  Draft
  Open
  Paid
  Overdue
  Void
}

enum DocumentCategory {
  Operations
  Support
  Commercial
  Warranty
  Other
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role     @default(USER)

  profile Profile?

  tasks Task[]

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workbenchTasks        WorkbenchTask[]        @relation("WorkbenchTaskOwner")
  workbenchTaskComments WorkbenchTaskComment[] @relation("WorkbenchTaskCommentAuthor")
  workbenchTaskLinks    WorkbenchTaskLink[]    @relation("WorkbenchTaskLinkOwner")
  mapBoxes              MapBox[]               @relation("UserMapBoxes")

  securityPropertiesOwned      SecurityProperty[]       @relation("SecurityPropertyOwner")
  securityPropertyMemberships  SecurityPropertyMember[]
  securityAuditLogsAsActor     SecurityAuditLog[]       @relation("SecurityAuditLogActor")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean   @default(false)
  status    String    @default("todo")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  scope     TaskScope @default(PORTAL)

  @@index([userId])
  @@index([userId, scope])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkbenchTask {
  id        String              @id @default(cuid())
  title     String
  client    String
  dueDate   DateTime?
  assignee  String
  status    WorkbenchTaskStatus @default(Open)
  priority  WorkbenchTaskPriority @default(Medium)

  mapX Float @default(40)
  mapY Float @default(40)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User? @relation("WorkbenchTaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  comments      WorkbenchTaskComment[]
  outgoingLinks WorkbenchTaskLink[] @relation("WorkbenchTaskLinkSource")
  incomingLinks WorkbenchTaskLink[] @relation("WorkbenchTaskLinkTarget")

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([ownerId, updatedAt])
}

model WorkbenchTaskLink {
  id           String @id @default(cuid())
  ownerId      String
  sourceTaskId String
  targetTaskId String
  createdAt    DateTime @default(now())

  owner      User          @relation("WorkbenchTaskLinkOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sourceTask WorkbenchTask @relation("WorkbenchTaskLinkSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask WorkbenchTask @relation("WorkbenchTaskLinkTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([ownerId, sourceTaskId, targetTaskId])
  @@index([ownerId])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

model WorkbenchTaskComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  taskId String
  task   WorkbenchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String?
  author   User? @relation("WorkbenchTaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model MapBox {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserMapBoxes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, order])
}

model SecurityProperty {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  nickname    String?
  description String?
  siteLabel   String?
  siteTimezone String?
  isActive    Boolean  @default(true)

  owner User @relation("SecurityPropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members        SecurityPropertyMember[]
  zones          SecurityZone[]
  devices        SecurityDevice[]
  alerts         SecurityAlert[]
  events         SecurityEvent[]
  serviceTickets SecurityServiceTicket[]
  invoices       SecurityInvoice[]
  documents      SecurityDocument[]
  auditLogs      SecurityAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([ownerId, updatedAt])
}

model SecurityPropertyMember {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  accessRole SecurityPropertyAccessRole @default(Viewer)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([userId])
  @@index([propertyId])
}

model SecurityZone {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  statusLabel String   @default("Not mapped")
  sortOrder   Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  devices  SecurityDevice[]
  alerts   SecurityAlert[]
  events   SecurityEvent[]

  @@index([propertyId])
  @@index([propertyId, sortOrder])
}

model SecurityDevice {
  id                 String   @id @default(cuid())
  propertyId         String
  zoneId             String?
  name               String
  deviceType         SecurityDeviceType
  status             SecurityDeviceStatus @default(UNCONFIGURED)
  manufacturer       String?
  modelName          String?
  serialNumber       String?
  firmwareVersion    String?
  ipAddress          String?
  resolutionLabel    String?
  preferredTransport CameraTransport?
  supportsOnvif      Boolean  @default(false)
  supportsRtsp       Boolean  @default(false)
  supportsPtz        Boolean  @default(false)
  isRecordingEnabled Boolean  @default(false)
  installedAt        DateTime?
  lastSeenAt         DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zone     SecurityZone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  streamProfiles CameraStreamProfile[]
  healthSamples  CameraHealthSample[]
  snapshots      Snapshot[]
  recordingClips RecordingClip[]
  alerts         SecurityAlert[]
  events         SecurityEvent[]

  @@index([propertyId])
  @@index([propertyId, deviceType])
  @@index([propertyId, status])
  @@index([propertyId, deviceType, updatedAt])
  @@index([zoneId])
}

model CameraStreamProfile {
  id           String   @id @default(cuid())
  deviceId     String
  label        String
  kind         CameraStreamKind   @default(LIVE)
  transport    CameraTransport
  status       CameraStreamStatus @default(UNCONFIGURED)
  streamPath   String?
  width        Int?
  height       Int?
  fps          Int?
  bitrateKbps  Int?
  codec        String?
  isPrimary    Boolean  @default(false)
  lastCheckedAt DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  device SecurityDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([deviceId, status])
  @@index([deviceId, kind])
}

model CameraHealthSample {
  id            String   @id @default(cuid())
  deviceId      String
  isOnline      Boolean
  latencyMs     Int?
  bitrateKbps   Int?
  frameRate     Float?
  packetLossPct Float?
  note          String?
  capturedAt    DateTime @default(now())

  device SecurityDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, capturedAt])
}

model Snapshot {
  id         String   @id @default(cuid())
  deviceId   String
  storageKey String
  previewUrl String?
  width      Int?
  height     Int?
  bytes      Int?
  capturedAt DateTime @default(now())

  device SecurityDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, capturedAt])
}

model RecordingClip {
  id         String   @id @default(cuid())
  deviceId   String
  storageKey String
  previewUrl String?
  mimeType   String?
  bytes      Int?
  startedAt  DateTime
  endedAt    DateTime
  durationSec Int?
  createdAt  DateTime @default(now())

  device SecurityDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, startedAt])
}

model SecurityAlert {
  id         String   @id @default(cuid())
  propertyId String
  zoneId     String?
  deviceId   String?
  severity   SecurityAlertSeverity @default(INFO)
  status     SecurityAlertStatus   @default(Open)
  title      String
  detail     String?
  triggeredAt DateTime @default(now())
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zone     SecurityZone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  device   SecurityDevice?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([propertyId, status])
  @@index([propertyId, triggeredAt])
  @@index([zoneId])
  @@index([deviceId])
}

model SecurityEvent {
  id         String   @id @default(cuid())
  propertyId String
  zoneId     String?
  deviceId   String?
  eventType  SecurityEventType @default(MANUAL)
  title      String
  detail     String?
  actorLabel String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zone     SecurityZone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  device   SecurityDevice?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([propertyId, occurredAt])
  @@index([zoneId])
  @@index([deviceId])
}

model SecurityServiceTicket {
  id          String   @id @default(cuid())
  propertyId  String
  title       String
  detail      String?
  priority    ServiceTicketPriority @default(Medium)
  status      ServiceTicketStatus   @default(Open)
  openedByLabel String?
  scheduledFor DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([propertyId, priority])
}

model SecurityInvoice {
  id           String   @id @default(cuid())
  propertyId   String
  invoiceNumber String? @unique
  amountCents  Int
  currency     String   @default("USD")
  dueDate      DateTime
  status       InvoiceStatus @default(Open)
  issuedAt     DateTime @default(now())
  paidAt       DateTime?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([propertyId, dueDate])
}

model SecurityDocument {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  category   DocumentCategory @default(Operations)
  summary    String?
  storageKey String?
  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property SecurityProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, category])
  @@index([propertyId, uploadedAt])
}

model SecurityAuditLog {
  id          String   @id @default(cuid())
  propertyId  String?
  actorUserId String?
  entityType  String
  entityId    String?
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  property  SecurityProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  actorUser User?             @relation("SecurityAuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([propertyId, createdAt])
  @@index([actorUserId, createdAt])
}